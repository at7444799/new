# =========================================
# CreatorOS AI – Environment Variables
# Copy this file to .env and fill in values
# =========================================

# ─── App Configuration ───────────────────
VITE_APP_NAME=CreatorOS AI
VITE_APP_URL=http://localhost:5173

# ─── Supabase (Database & Auth) ──────────
# Get from: https://supabase.com/dashboard
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── AI Providers (Choose one or more) ───
# OpenAI: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=sk-...

# Anthropic Claude: https://console.anthropic.com
VITE_CLAUDE_API_KEY=sk-ant-...

# DeepSeek: https://platform.deepseek.com
VITE_DEEPSEEK_API_KEY=sk-...

# NVIDIA NIM: https://integrate.api.nvidia.com
VITE_NVIDIA_API_KEY=nvapi-...

# Default AI provider: mock | openai | claude | deepseek | nvidia
VITE_DEFAULT_AI_PROVIDER=mock

# ─── Payment Gateways ────────────────────
# Razorpay (India): https://razorpay.com/docs
VITE_RAZORPAY_KEY_ID=rzp_test_...
VITE_RAZORPAY_KEY_SECRET=your_secret_key

# Stripe (International): https://stripe.com/docs
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
VITE_STRIPE_SECRET_KEY=sk_test_...

# ─── Analytics (Optional) ────────────────
VITE_GA_MEASUREMENT_ID=G-...

# ─── Email (Optional – for notifications) ─
VITE_RESEND_API_KEY=re_...
